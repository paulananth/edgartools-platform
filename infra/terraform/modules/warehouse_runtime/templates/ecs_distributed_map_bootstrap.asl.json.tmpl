{
  "Comment": "Seed CIK universe then bootstrap companies in parallel batches of 100.",
  "StartAt": "SeedUniverse",
  "States": {
    "SeedUniverse": {
      "Type": "Task",
      "Resource": "arn:aws:states:::ecs:runTask.sync",
      "Parameters": {
        "LaunchType": "FARGATE",
        "Cluster": "${cluster_arn}",
        "TaskDefinition": "${seed_task_definition_arn}",
        "PropagateTags": "TASK_DEFINITION",
        "NetworkConfiguration": {
          "AwsvpcConfiguration": {
            "AssignPublicIp": "ENABLED",
            "SecurityGroups": ${security_groups_json},
            "Subnets": ${subnets_json}
          }
        },
        "Overrides": {
          "ContainerOverrides": [
            {
              "Name": "${container_name}",
              "Command.$": "States.Array('seed-universe', '--run-id', $$.Execution.Name)"
            }
          ]
        }
      },
      "Retry": [
        {
          "ErrorEquals": ["States.TaskFailed"],
          "IntervalSeconds": 60,
          "BackoffRate": 2.0,
          "MaxAttempts": 2
        }
      ],
      "Next": "BatchBootstrap"
    },
    "BatchBootstrap": {
      "Type": "Map",
      "MaxConcurrency": ${batch_concurrency},
      "ItemReader": {
        "Resource": "arn:aws:states:::s3:getObject",
        "ReaderConfig": {
          "InputType": "JSONL",
          "MaxItems": 100000
        },
        "Parameters": {
          "Bucket": "${bronze_bucket_name}",
          "Key.$": "States.Format('warehouse/bronze/reference/cik_universe/runs/{}/cik_batches.jsonl', $$.Execution.Name)"
        }
      },
      "ItemProcessor": {
        "ProcessorConfig": {
          "Mode": "DISTRIBUTED",
          "ExecutionType": "STANDARD"
        },
        "StartAt": "RunBatch",
        "States": {
          "RunBatch": {
            "Type": "Task",
            "Resource": "arn:aws:states:::ecs:runTask.sync",
            "Parameters": {
              "LaunchType": "FARGATE",
              "Cluster": "${cluster_arn}",
              "TaskDefinition": "${batch_task_definition_arn}",
              "PropagateTags": "TASK_DEFINITION",
              "NetworkConfiguration": {
                "AwsvpcConfiguration": {
                  "AssignPublicIp": "ENABLED",
                  "SecurityGroups": ${security_groups_json},
                  "Subnets": ${subnets_json}
                }
              },
              "Overrides": {
                "ContainerOverrides": [
                  {
                    "Name": "${container_name}",
                    "Command.$": "States.Array('bootstrap-batch', '--cik-list', $.cik_list, '--run-id', $$.Execution.Name)"
                  }
                ]
              }
            },
            "Retry": [
              {
                "ErrorEquals": ["States.TaskFailed"],
                "IntervalSeconds": 120,
                "BackoffRate": 2.0,
                "MaxAttempts": 2
              }
            ],
            "End": true
          }
        }
      },
      "End": true
    }
  }
}
