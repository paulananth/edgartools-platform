provisioning_state_bucket = "edgartools-prod-tfstate"
provisioning_state_key    = "accounts/prod/terraform.tfstate"
provisioning_state_region = "us-east-1"

# Optional after Snowflake provisioning has been initialized.
snowflake_state_bucket = "edgartools-prod-tfstate"
snowflake_state_key    = "snowflake/prod/terraform.tfstate"
snowflake_state_region = "us-east-1"

# Set true only for the first AWS access apply before Snowflake emits
# snowflake_manifest_subscriber_arn.
snowflake_bootstrap_enabled = false
