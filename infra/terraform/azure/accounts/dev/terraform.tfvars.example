location                = "eastus"
storage_account_name    = "edgartoolsdevlake01"
container_registry_name = "edgartoolsdevacr01"
key_vault_name          = "edgartools-dev-kv-01"
container_image         = "edgartoolsdevacr01.azurecr.io/edgar-warehouse:replace-me"

# Store EDGAR_IDENTITY in Key Vault with infra/scripts/bootstrap-azure-secrets.sh.

# Optional scheduled run after validation:
# daily_incremental_schedule = "0 7 * * *"

# Optional MDM data plane. Names must be globally unique.
# enable_mdm                        = true
# mdm_sql_server_name               = "edgartools-dev-mdm-sql-01"
# mdm_sql_location                  = "eastus2"
# mdm_neo4j_storage_account_name    = "edgartoolsdevneo4j01"
# mdm_neo4j_external_enabled        = false
# mdm_api_external_enabled          = false
# mdm_silver_duckdb_path            = "abfss://warehouse@<account>.dfs.core.windows.net/warehouse/silver/sec/silver.duckdb"
# mdm_api_keys                      = ["replace-with-dev-api-key"]
#
# Optional operator firewall rule for direct SQL access:
# mdm_sql_firewall_rules = {
#   operator = {
#     start_ip_address = "203.0.113.10"
#     end_ip_address   = "203.0.113.10"
#   }
# }
