storage_account_name    = "edgartoolsprodstorage01"
container_registry_name = "edgartoolsprodacr01"
key_vault_name          = "edgartools-prod-kv-01"

# Store runtime values in Key Vault with post-infra operator scripts.
# Terraform does not create Container Apps jobs/apps, schedules, or Key Vault
# secret values.

